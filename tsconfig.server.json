{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node10",
    "target": "ES2022",
    "ignoreDeprecations": "6.0",
    "outDir": "dist/server",
    "rootDir": "src/server",
    "lib": ["ES2022"],
    "types": ["node"],
    "noEmit": false,
    "sourceMap": true,
    "declaration": false,
    "isolatedModules": false
  },
  "include": ["src/server/**/*.ts"]
}
