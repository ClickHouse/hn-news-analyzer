# =============================================================================
# Copy this file to .env and fill in your ClickStack endpoint + auth token.
# Values are pulled from the ClickStack Console:
#   "Configure your OpenTelemetry exporter" → "Env vars" tab
# =============================================================================

# === Backend telemetry ======================================================
# Sourced by run.sh and consumed by `opentelemetry-instrument` when the AFTER
# toggle is active (HyperDX flavor; see https://www.hyperdx.io/docs/install/javascript).
OTEL_SERVICE_NAME=hn-analyzer-api
OTEL_EXPORTER_OTLP_ENDPOINT=https://YOUR_TENANT.otel.REGION.aws.clickhouse.com:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# IMPORTANT: use HYPERDX_API_KEY (paste the same token from the console here).
# The HyperDX SDK uses this one var to wire up Authorization headers for
# ALL three signals — traces, metrics, AND logs (console.log capture).
# Setting only OTEL_EXPORTER_OTLP_HEADERS works for traces+metrics but the
# console-capture log path can drop the env headers, so logs silently fail
# to ship. Stick to HYPERDX_API_KEY.
HYPERDX_API_KEY=YOUR_INGESTION_TOKEN

OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp

# === Frontend telemetry (OPTIONAL — for demo Step 5 only) ==================
# No dedicated frontend env vars. When you opt into Step 5 (browser session
# replay), vite.config.ts reuses the OTEL_EXPORTER_OTLP_ENDPOINT above and
# parses the bearer token out of OTEL_EXPORTER_OTLP_HEADERS (or falls back to
# HYPERDX_API_KEY). Both are then baked into the browser bundle at build time
# as compile-time constants.
#
# WARNING: that token ends up in the public browser bundle. Anyone inspecting
# your booth laptop's network tab can read it. Use a throwaway / demo-scoped
# ingestion token, NOT your production one. Don't commit .env.

# === ClickHouse data source (OPTIONAL) =====================================
# Defaults point at ClickHouse's public read-only demo cluster
# (sql-clickhouse.clickhouse.com, user "demo"). The demo works out of the box
# with no values here. Uncomment to point at a different dataset.
# CLICKHOUSE_URL=https://sql-clickhouse.clickhouse.com:8443
# CLICKHOUSE_USERNAME=demo
# CLICKHOUSE_PASSWORD=
# CLICKHOUSE_DATABASE=hackernews

# === ClickStack tenant (used by reset.sh ONLY) =============================
# These point at the ClickHouse Cloud instance that backs YOUR ClickStack
# tenant — the same place HYPERDX_API_KEY ships telemetry to. ./reset.sh uses
# them to TRUNCATE the otel.* tables (otel_logs, otel_traces, the five
# otel_metrics_* tables, and hyperdx_sessions) between booth sessions so the
# next visitor sees a clean ClickStack UI.
#
# The runtime app does NOT read these — it only talks to ClickStack via OTLP.
# If unset, ./reset.sh skips the TRUNCATE step with a warning and still does
# everything else. Database is hardcoded to "otel"; HTTPS port to 8443.
# CLICKHOUSE_HOST=YOUR_TENANT.REGION.aws.clickhouse.cloud
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=
